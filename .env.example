# Contact form email delivery.
CONTACT_EMAIL_SMTP_HOST=
CONTACT_EMAIL_SMTP_PORT=587
CONTACT_EMAIL_SMTP_USER=
CONTACT_EMAIL_SMTP_PASSWORD=
CONTACT_EMAIL_FROM=Yellow Rose Capital <no-reply@yellowrosecapital.com>

# Optional webhook that receives analytics events.
ANALYTICS_WEBHOOK_URL=

# Stage 6 lead workflow destinations.
