LEAD_CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/3903592/u73uc7w/
LEAD_NOTIFICATION_WEBHOOK_URL=
LEAD_FOLLOWUP_WEBHOOK_URL=
LEAD_AUDIT_WEBHOOK_URL=
LEAD_OWNER_NAME=Investor Relations

# Stage 7 private investor communications.
INVESTOR_RELATIONS_API_KEY=
